# Copy to /etc/skinbox/skinbox.env and fill in real values.
# chmod 600 — root-only read.

SPRING_PROFILES_ACTIVE=prod

# Database (Postgres)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.internal:5432/skinbox
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=skinbox
SPRING_DATASOURCE_PASSWORD=CHANGE_ME
SPRING_JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_DDL=validate
FLYWAY_ENABLED=true

# Stripe (live mode)
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_SUCCESS_URL=https://skinbox.market/?deposit=success
STRIPE_CANCEL_URL=https://skinbox.market/?deposit=cancel

# Steam
STEAM_API_KEY=
STEAM_REALM=https://skinbox.market/
STEAM_RETURN_URL=https://skinbox.market/api/auth/steam/return

# Admin bootstrap — comma-separated Steam ID64s that auto-get ADMIN role on
# login. Default is baked into application.yml (76561199839805014). Override
# here to rotate the owner or add more admins.
ADMIN_BOOTSTRAP_STEAM_IDS=76561199839805014

# Security
CORS_ALLOWED_ORIGINS=https://skinbox.market
COOKIE_SECURE=true
# Lax (not Strict) — Steam OpenID and Stripe Checkout redirect the browser
# back to skinbox.market from their domains. SameSite=Strict blocks the
# session cookie on those cross-site top-level navigations, causing the
# session to appear lost after login/deposit.
COOKIE_SAME_SITE=lax
SECURITY_HSTS=true
SECURITY_CSRF=true
SECURITY_VERBOSE_ERRORS=false

# Lock down everything not needed in prod
H2_CONSOLE=false
SWAGGER_ENABLED=false
# Actuator is disabled by default via management.server.port=-1 — do NOT
# expose the actuator servlet on the public port in prod. If you need a
# management port behind a firewall, set ACTUATOR_PORT=9090.
# ACTUATOR_PORT=9090

# Logging
LOG_FILE=/var/log/skinbox/skinbox.log

# CSR goodwill credit cap in USD
CSR_CREDIT_CAP=25.00

# Email — Resend SMTP (or any SMTP-compatible relay)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_CHANGE_ME
SMTP_AUTH=true
SMTP_STARTTLS=true
APP_EMAIL_FROM=noreply@skinbox.market
APP_EMAIL_FROM_NAME=SkinBox
APP_PUBLIC_URL=https://skinbox.market

# Sentry — error tracking + performance
SENTRY_DSN=https://abc123@o123456.ingest.us.sentry.io/789
SENTRY_ENV=production

# Trade escrow auto-release window (days). Default is 8 days.
TRADE_AUTO_RELEASE_DAYS=8

# JVM tuning (systemd unit passes these through automatically)
SERVER_PORT=8080

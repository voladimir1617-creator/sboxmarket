# Copy to /etc/skinbox/skinbox.env and fill in real values.
# chmod 600 — root-only read.

SPRING_PROFILES_ACTIVE=prod

# Database (Postgres)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.internal:5432/skinbox
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=skinbox
SPRING_DATASOURCE_PASSWORD=CHANGE_ME
SPRING_JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_DDL=validate
FLYWAY_ENABLED=true

# Stripe (live mode)
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_SUCCESS_URL=https://skinbox.example/?deposit=success
STRIPE_CANCEL_URL=https://skinbox.example/?deposit=cancel

# Steam
STEAM_API_KEY=
STEAM_REALM=https://skinbox.example/
STEAM_RETURN_URL=https://skinbox.example/api/auth/steam/return

# Admin bootstrap — comma-separated Steam ID64s that auto-get ADMIN role on
# login. Default is baked into application.yml (76561199839805014). Override
# here to rotate the owner or add more admins.
ADMIN_BOOTSTRAP_STEAM_IDS=76561199839805014

# Security
CORS_ALLOWED_ORIGINS=https://skinbox.example
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
SECURITY_HSTS=true
SECURITY_CSRF=true
SECURITY_VERBOSE_ERRORS=false

# Lock down everything not needed in prod
H2_CONSOLE=false
SWAGGER_ENABLED=false
# Actuator is disabled by default via management.server.port=-1 — do NOT
# expose the actuator servlet on the public port in prod. If you need a
# management port behind a firewall, set ACTUATOR_PORT=9090.
# ACTUATOR_PORT=9090

# Logging
LOG_FILE=/var/log/skinbox/skinbox.log

# CSR goodwill credit cap in USD
CSR_CREDIT_CAP=25.00

# JVM tuning (systemd unit passes these through automatically)
SERVER_PORT=8080
